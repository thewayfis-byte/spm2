<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Услуги - NowkeArt</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">NowkeArt</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <% if (user) { %>
                        <li class="nav-item"><a class="nav-link" href="/orders">Мои заказы</a></li>
                        <li class="nav-item"><a class="nav-link" href="/support">Поддержка</a></li>
                        <li class="nav-item"><a class="nav-link" href="/auth/logout">Выход</a></li>
                    <% } else { %>
                        <li class="nav-item"><a class="nav-link" href="/auth/login">Вход</a></li>
                        <li class="nav-item"><a class="nav-link" href="/auth/register">Регистрация</a></li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-5">
        <h1 class="mb-5">Наши услуги</h1>

        <div class="row">
            <% services.forEach(service => { %>
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title"><%= service.service %></h5>
                            <p class="card-text text-muted"><%= service.about %></p>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="h4 mb-0"><%= service.price %> р</span>
                                <% if (user) { %>
                                    <a href="/orders/create" class="btn btn-primary btn-sm">
                                        <i class="fas fa-shopping-cart"></i> Заказать
                                    </a>
                                <% } else { %>
                                    <a href="/auth/register" class="btn btn-primary btn-sm">
                                        <i class="fas fa-user-plus"></i> Регистрация
                                    </a>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
    </div>

    <footer class="bg-dark text-white text-center py-4 mt-5">
        <div class="container">
            <p>&copy; 2024 NowkeArt. Все права защищены.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
