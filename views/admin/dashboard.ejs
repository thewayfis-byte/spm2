<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Панель управления - NowkeArt</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="d-flex">
        <div class="sidebar col-md-3 col-lg-2">
            <div class="sidebar-title">
                <i class="fas fa-cog"></i> Управление
            </div>
            <a href="/admin" class="active"><i class="fas fa-chart-line"></i> Статистика</a>
            <a href="/admin/orders"><i class="fas fa-shopping-cart"></i> Заказы</a>
            <a href="/admin/users"><i class="fas fa-users"></i> Пользователи</a>
            <a href="/admin/services"><i class="fas fa-list"></i> Услуги</a>
            <a href="/admin/staff"><i class="fas fa-users-cog"></i> Сотрудники</a>
            <a href="/auth/logout"><i class="fas fa-sign-out-alt"></i> Выход</a>
        </div>

        <div class="main-content col-md-9 col-lg-10">
            <h1 class="mb-4">Панель управления</h1>

            <div class="row">
                <div class="col-md-3">
                    <div class="stat-card">
                        <i class="fas fa-shopping-cart" style="color: var(--primary);"></i>
                        <div class="stat-number"><%= activeOrders %></div>
                        <div class="stat-label">Активных заказов</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <i class="fas fa-users" style="color: var(--success);"></i>
                        <div class="stat-number"><%= totalUsers %></div>
                        <div class="stat-label">Пользователей</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <i class="fas fa-ruble-sign" style="color: var(--warning);"></i>
                        <div class="stat-number"><%= totalRevenue %></div>
                        <div class="stat-label">Доход (руб)</div>
                    </div>
                </div>
            </div>

            <div class="mt-5">
                <h3>Недавние заказы</h3>
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>№</th>
                            <th>Клиент</th>
                            <th>Услуга</th>
                            <th>Статус</th>
                            <th>Цена</th>
                            <th>Дата</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% recentOrders.forEach(order => { %>
                            <tr>
                                <td><%= order.number %></td>
                                <td><%= order.first_name %> <%= order.last_name %></td>
                                <td><%= order.service_name || order.service %></td>
                                <td>
                                    <span class="badge badge-<%= order.status === 'Готов' ? 'success' : 'warning' %>">
                                        <%= order.status %>
                                    </span>
                                </td>
                                <td><%= order.price || 'N/A' %> р</td>
                                <td><%= new Date(order.created_at).toLocaleDateString('ru-RU') %></td>
                                <td>
                                    <a href="/admin/orders" class="btn btn-sm btn-primary">Просмотр</a>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
