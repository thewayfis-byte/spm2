<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Мои заказы - NowkeArt</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">NowkeArt</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/orders">Мои заказы</a></li>
                    <li class="nav-item"><a class="nav-link" href="/orders/create">Новый заказ</a></li>
                    <li class="nav-item"><a class="nav-link" href="/support">Поддержка</a></li>
                    <li class="nav-item"><a class="nav-link" href="/auth/logout">Выход</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-5">
        <div class="row">
            <div class="col-md-12">
                <h1 class="mb-4">Мои заказы</h1>

                <a href="/orders/create" class="btn btn-success mb-3">
                    <i class="fas fa-plus"></i> Создать новый заказ
                </a>

                <% if (orders.length === 0) { %>
                    <div class="alert alert-info">
                        У вас нет заказов. <a href="/orders/create">Создайте первый заказ</a>
                    </div>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>№</th>
                                    <th>Услуга</th>
                                    <th>Статус</th>
                                    <th>Дизайнер</th>
                                    <th>Дата создания</th>
                                    <th>Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% orders.forEach(order => { %>
                                    <tr>
                                        <td><strong><%= order.number %></strong></td>
                                        <td><%= order.service_name || order.service %></td>
                                        <td>
                                            <span class="badge
                                                <% if (order.status === 'Готов') { %>badge-success<% }
                                                   else if (order.status === 'Выполняется') { %>badge-primary<% }
                                                   else if (order.status === 'Проверяется') { %>badge-warning<% }
                                                   else { %>badge-info<% } %>">
                                                <%= order.status %>
                                            </span>
                                        </td>
                                        <td>
                                            <% if (order.designer_name) { %>
                                                <%= order.designer_name %>
                                            <% } else { %>
                                                <span class="text-muted">-</span>
                                            <% } %>
                                        </td>
                                        <td><%= new Date(order.created_at).toLocaleDateString('ru-RU') %></td>
                                        <td>
                                            <a href="/orders/<%= order.id %>" class="btn btn-sm btn-primary">
                                                <i class="fas fa-eye"></i> Просмотр
                                            </a>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <footer class="bg-dark text-white text-center py-4 mt-5">
        <div class="container">
            <p>&copy; 2024 NowkeArt. Все права защищены.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
