<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Создать заказ - NowkeArt</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">NowkeArt</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/orders">Мои заказы</a></li>
                    <li class="nav-item"><a class="nav-link" href="/support">Поддержка</a></li>
                    <li class="nav-item"><a class="nav-link" href="/auth/logout">Выход</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-5">
        <div class="row">
            <div class="col-md-8 offset-md-2">
                <div class="card">
                    <div class="card-body p-5">
                        <h2 class="card-title mb-4">Создание нового заказа</h2>

                        <form id="orderForm">
                            <div class="form-group mb-4">
                                <label for="service_id" class="form-label">Выберите услугу *</label>
                                <select class="form-select form-control" id="service_id" name="service_id" required>
                                    <option value="">-- Выберите услугу --</option>
                                    <% services.forEach(service => { %>
                                        <option value="<%= service.id %>">
                                            <%= service.service %> (<%= service.price %> р)
                                        </option>
                                    <% }); %>
                                </select>
                            </div>

                            <div class="form-group mb-4">
                                <label for="description" class="form-label">Описание заказа *</label>
                                <textarea class="form-control" id="description" name="description" rows="5"
                                          placeholder="Опишите что вы хотите получить, дайте как можно больше деталей..."
                                          required></textarea>
                                <small class="form-text text-muted">Чем подробнее вы опишете, тем лучше результат</small>
                            </div>

                            <div class="form-group mb-4">
                                <label for="arms" class="form-label">Дополнительные требования</label>
                                <input type="text" class="form-control" id="arms" name="arms"
                                       placeholder="Цвета, размеры, стиль и т.д.">
                            </div>

                            <div class="form-group mb-4">
                                <label for="files" class="form-label">Загрузить файлы</label>
                                <div class="file-upload-area">
                                    <input type="file" id="files" name="files" multiple hidden>
                                    <i class="fas fa-cloud-upload-alt fa-3x text-primary mb-3"></i>
                                    <p>Перетащите файлы сюда или нажмите для выбора</p>
                                    <small>Максимум 5 файлов, до 10MB каждый</small>
                                </div>
                                <div class="file-list"></div>
                            </div>

                            <div class="form-group">
                                <button type="submit" class="btn btn-primary btn-lg w-100">
                                    <i class="fas fa-plus"></i> Создать заказ
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
    <script>
        document.getElementById('orderForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            const formData = new FormData();
            formData.append('service_id', document.getElementById('service_id').value);
            formData.append('description', document.getElementById('description').value);
            formData.append('arms', document.getElementById('arms').value);

            const files = document.getElementById('files').files;
            for (let file of files) {
                formData.append('files', file);
            }

            try {
                const response = await fetch('/orders/create', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    showAlert('Заказ создан успешно!', 'success');
                    setTimeout(() => {
                        window.location.href = `/orders/${result.order_id}`;
                    }, 2000);
                } else {
                    showAlert(result.message || 'Ошибка создания заказа', 'danger');
                }
            } catch (error) {
                console.error('Ошибка:', error);
                showAlert('Ошибка при создании заказа', 'danger');
            }
        });
    </script>
</body>
</html>
